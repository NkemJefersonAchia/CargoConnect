# ─────────────────────────────────────────────
#  CargoConnect — Environment Variables Template
#  Copy this file to .env and fill in the values
#  Never commit your .env file to GitHub
# ─────────────────────────────────────────────

# Flask secret key — any random string, used to sign session cookies
SECRET_KEY=your-random-secret-key-here

# Aiven PostgreSQL connection string
# Get this from the project lead or from your Aiven service overview page
DATABASE_URL=postgresql://avnadmin:YOUR_PASSWORD@pg-2b4808d0-alustudent-792a.i.aivencloud.com:22910/defaultdb?sslmode=require

# Path to the Aiven SSL certificate (must be in the project root)
PGSSLROOTCERT=ca.pem

# Flask environment settings
FLASK_ENV=development
FLASK_DEBUG=1

# ─────────────────────────────────────────────
#  MTN MoMo — NOT REQUIRED
#  Payment is fully simulated in this project.
#  These variables can be left blank.
# ─────────────────────────────────────────────
MOMO_API_KEY=
MOMO_USER_ID=
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
